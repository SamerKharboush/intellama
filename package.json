{
  "name": "llama-cli",
  "version": "1.1.0",
  "description": "Optimized llama.cpp terminal launcher for Intel x64 Macs, tuned for Mac Pro 2013 Ivy Bridge with Apple Accelerate BLAS.",
  "main": "bin/llama-cli.js",
  "bin": {
    "llama-cli": "bin/llama-cli.js"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "x64"
  ],
  "files": [
    "assets/",
    "bin/",
    "scripts/",
    "src/",
    "vendor/llama-cpp-macpro.tar.gz"
  ],
  "scripts": {
    "pack:release": "zsh scripts/package-release.sh",
    "postinstall": "node scripts/postinstall.js",
    "start": "node bin/llama-cli.js",
    "test": "zsh -n src/llama-launcher.sh && node --check bin/llama-cli.js && node --check scripts/postinstall.js"
  },
  "keywords": [
    "llama",
    "llama.cpp",
    "llm",
    "local-ai",
    "mac",
    "intel",
    "mac-pro",
    "inference",
    "gguf",
    "ai",
    "cli",
    "terminal"
  ],
  "author": "Samer Kharboush",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamerKharboush/llama-cli.git"
  },
  "bugs": {
    "url": "https://github.com/SamerKharboush/llama-cli/issues"
  },
  "homepage": "https://github.com/SamerKharboush/llama-cli#readme",
  "engines": {
    "node": ">=14.0.0"
  }
}
